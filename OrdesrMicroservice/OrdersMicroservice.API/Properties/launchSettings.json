    },
    "https": {
        "commandName": "Project",
        "launchBrowser": true,
        "environmentVariables": {
            "ASPNETCORE_ENVIRONMENT": "Development",
            "MONGODB_HOST": "localhost",
            "MONGODB_PORT": "27017",
            "MONGODB_DATABASE": "OrdersDatabase",
            "UsersMicroserviceName": "localhost",
            "UsersMicroservicePort": "9090",
            "ProductsMicroserviceName": "localhost",
            "ProductsMicroservicePort": "5201"
        },
        "dotnetRunMessages": true,
        "applicationUrl": "https://localhost:7056;http://localhost:5287"
    },
    "IIS Express": {
      "commandName": "IISExpress",
      "launchBrowser": true,
        "environmentVariables": {
            "ASPNETCORE_ENVIRONMENT": "Development",
            "MONGODB_HOST": "localhost",
            "MONGODB_PORT": "27017",
            "MONGODB_DATABASE": "OrdersDatabase",
            "UsersMicroserviceName": "localhost",
            "UsersMicroservicePort": "9090",
            "ProductsMicroserviceName": "localhost",
            "ProductsMicroservicePort": "5201"
        }
    },
    "Container (Dockerfile)": {
      "commandName": "Docker",
      "launchBrowser": true,
      "launchUrl": "{Scheme}://{ServiceHost}:{ServicePort}",
        "environmentVariables": {
            "ASPNETCORE_HTTPS_PORTS": "8081",
            "ASPNETCORE_HTTP_PORTS": "8080",
            "MONGODB_DATABASE": "OrdersDatabase",
            "UsersMicroserviceName": "localhost",
            "UsersMicroservicePort": "9090"
        },
      "publishAllPorts": true,
      "useSSL": true
    }
  },
  "$schema": "http://json.schemastore.org/launchsettings.json",
  "iisSettings": {
    "windowsAuthentication": false,
    "anonymousAuthentication": true,
    "iisExpress": {
      "applicationUrl": "http://localhost:1154",
