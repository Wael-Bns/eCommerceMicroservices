{
    "Routes": [
        {
            "UpstreamPathTemplate": "/gateway/Orders",
            "DownstreamPathTemplate": "/api/Orders",
            "DownstreamHostAndPorts": [
                {
                    "Host": "ordersmicroservice.api",
                    "Port": 8080
                }
            ],
            "UpstreamHttpMethod": [ "GET", "POST", "OPTIONS" ],
            "UpstreamScheme": "http"
        }
    ],
    "GlobalConfiguration": {
        "BaseUrl": "http://localhost:4000"
    }
}
